{
  "name": "fanyi-extension",
  "version": "0.63.3",
  "description": "简简单单中英文翻译 - 支持 Chrome, Firefox, Android Firefox",
  "homepage": "https://github.com/saga/fanyi-extension#readme",
  "bugs": {
    "url": "https://github.com/saga/fanyi-extension/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saga/fanyi-extension.git"
  },
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build ",
    "build:firefox": "wxt build -b firefox ",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@wxt-dev/storage": "^1.2.8",
    "compromise": "^14.15.1",
    "element-plus": "^2.14.0",
    "vue": "^3.5.34",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/module-vue": "^1.0.3",
    "@wxt-dev/webextension-polyfill": "^1.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.3",
    "wxt": "^0.20.26"
  }
}
